# 真实 config.toml 不应提交到 git。
# 复制本文件为 config.toml 后再填写自己的模型和密钥配置。

[runtime]
# output 不修改原目录；writeback 会写回输入目录后续章节。
output_mode = "output"

# 开启后更利于断点续接和排查，但日志会包含小说正文。
save_full_prompts = true

[writing]
# 中文字数容差比例。0.1 表示允许目标区间上下浮动 10%。
word_count_tolerance_ratio = 0.1

# 留空表示关闭预算裁剪；填写整数后按确定性优先级裁剪检索结果。
retrieval_token_budget = ""

# 每章自动修订最多轮数。
max_revision_rounds = 3

# 每多少章生成一个区间摘要。长篇项目建议保持在 20-100 之间。
range_summary_chapter_span = 50

# story_merge 额外注入最近多少章单章分析；较早内容通过区间摘要和索引提供。
story_merge_recent_chapters = 20

# 连续生成多章时，生成章节跨过区间边界后刷新对应区间摘要。
refresh_range_summary_after_generation = true

# 生成的大纲、计划、正文中禁止出现这些词。默认避免把工具名或“水印”写进小说。
banned_generation_terms = ["墨连", "Inklink", "水印"]

[approvals]
# 默认关闭自动批准，避免用户错过关键规划节点。
auto_approve_outline = false
auto_approve_chapter_plan = false
auto_approve_scene_plan = false

# 谨慎开启：修订达到上限仍未通过时，可能让低质量章节进入输出流程。
auto_approve_review_failure = false

[cold_start]
# 默认关闭。开启后可先粗读历史章节、精读最近章节。
enabled = false

# 冷启动开启时，最近多少章按 deep 分析处理。
recent_chapters_to_deep_analyze = 50

[models.default]
# 可选：responses 或 chat_completions。
api = "responses"

# 模型名由用户配置，不硬编码。
model = "gpt-5.5"

# 可选：直接在 config.toml 写明文 API key。留空则读取 api_key_env。
# 明文 key 方便本地单机使用，但请确认 config.toml 已被 git 忽略。
api_key = ""

# api_key 留空时，从这个环境变量读取 API key。
api_key_env = "OPENAI_API_KEY"

# 留空使用 SDK 默认地址；兼容服务可填写自定义 /v1 base_url。
base_url = ""

# 空值不传给 SDK。reasoning_effort 非空时会原样传给服务端；
# 常见 OpenAI 值包括 none、minimal、low、medium、high、xhigh，
# 兼容服务或新模型自定义值也不会被本工具拦截。
temperature = ""
top_p = ""
reasoning_effort = ""
max_completion_tokens = ""

# 每次请求超时时间；留空使用 SDK 默认值。
timeout_seconds = ""

# SDK 请求失败后的最大重试次数。
max_retries = 2

# 每分钟请求数限制；留空表示不启用 rpm 限制。
rpm = 60

# 同一 profile 最大并发调用数。
max_concurrency = 4

[tasks]
# 未配置任务回退到 models.default。
chapter_extraction = "default"
worldbuilding_extraction = "default"
story_merge = "default"
range_summary = "default"
outline_planning = "default"
outline_chat = "default"
chapter_planning = "default"
chapter_plan_chat = "default"
scene_planning = "default"
scene_plan_chat = "default"
drafting = "default"
review = "default"
revision = "default"
